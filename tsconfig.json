{
  "extends": "@tsconfig/node18/tsconfig.json",
  "compilerOptions": {
    /* Output */
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "stripInternal": true,

    /* Language & Runtime */
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "moduleResolution": "node",

    /* Type System */
    "strict": false,
    "noImplicitAny": false,
    "preserveConstEnums": true,
    "skipLibCheck": true,

    /* Types */
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ],

    /* Quality of life */
    "newLine": "lf"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
