@prefix dpv:    <https://www.w3.org/ns/dpv#> .
@prefix dpv-pd: <https://www.w3.org/ns/dpv/pd#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix ex:     <https://example.org/privacy#> .

ex:nik
  a dpv:PersonalData ;
  skos:prefLabel "National Identification Number"@en ;
  dpv:hasPersonalDataCategory dpv-pd:NationalIdentificationNumber ;
  dpv:hasDataCategory dpv:HighlySensitivePersonalData ;
  ex:domain "identity" .

ex:bloodType
  a dpv:PersonalData ;
  skos:prefLabel "Blood Type"@en ;
  dpv:hasPersonalDataCategory dpv-pd:BloodType ;
  dpv:hasDataCategory dpv:SpecialCategoryPersonalData ;
  ex:domain "health" .
