@prefix dpv:  <https://w3id.org/dpv#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ex:   <https://example.org/privacy#> .

schema:identifier
  a dpv:PersonalData ;
  dct:description "Identifying Personal Data"@en ;
  dpv:hasPersonalData dpv:IdentifyingPersonalData ;
  dpv:hasDataCategory dpv:SensitivePersonalData ;
  ex:domain "identity" .

schema:bloodType
  a dpv:PersonalData ;
  dct:description "Blood Type"@en ;
  dpv:hasPersonalData dpv:PersonalData ;
  dpv:hasDataCategory dpv:SpecialCategoryPersonalData ;
  ex:domain "health" .
