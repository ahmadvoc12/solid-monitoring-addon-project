{
  "name": "opinionated-eslint-config",
  "version": "0.2.0",
  "description": "An opinionated linter configuration",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.ts"
