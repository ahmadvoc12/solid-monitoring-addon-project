{
  "@context": "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^7.0.0/components/context.jsonld",

  "@id": "urn:solid:audit-autologger",

  "@type": "HttpMiddleware",

  "http:name": "audit-autologger",
  "http:priority": 50,

  "http:handle": {
    "@type": "AuditAutologger",
    "require": "file:dist/audit/solid-audit-autologger.js",
    "arguments": {
      "logBasePath": "private/audit/access"
    }
  }
}
