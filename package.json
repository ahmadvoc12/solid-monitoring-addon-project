{
  "name": "@solid/community-server",
  "version": "7.1.7",
  "description": "Community Solid Server with Gateway + Audit",
  "license": "MIT",

  "main": "./dist/index.js",
  "bin": {
    "community-solid-server": "bin/server.js"
  },

  "engines": {
    "node": ">=18.0"
  },

  "scripts": {
    "start:gateway": "node gateway.mjs",
    "start": "npm run start:gateway",

    "start:css": "node ./bin/server.js -c config/file.json -f ./.data",

    "start:file": "node ./bin/server.js -c config/file.json -f ./.data",
    "start:file-root": "node ./bin/server.js -c config/file-root.json -f ./.data"
  },

  "dependencies": {
    "@solid/community-server": "^7.1.7"
  }
}
